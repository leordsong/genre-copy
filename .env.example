# 火山引擎 API 配置
# 复制此文件为 .env 并填入你的真实密钥
# 获取 API Key: https://console.volcengine.com/ark/region:ark+cn-beijing/apikey

ARK_API_KEY=你的API_KEY
ARK_MODEL=你的模型ID

# 火山引擎 AccessKey/SecretKey (用于账单查询)
# 获取地址: https://console.volcengine.com/iam/keymanage/
VOLC_ACCESS_KEY=你的AccessKey
VOLC_SECRET_KEY=你的SecretKey

# API 基础URL (通常不需要修改)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=7860
